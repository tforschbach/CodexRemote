# Copy this file to .env.local before you start the Mac companion.
# The companion reads .env and .env.local from the repo root.

# Required only if you want OpenAI dictation on iPhone.
OPENAI_API_KEY=your_openai_api_key_here

# Optional overrides.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional if you want to force the pairing host shown in the QR code.
# Leave this unset in most setups. The companion will try to use your Tailscale IP.
# TAILSCALE_HOST=100.64.0.2
